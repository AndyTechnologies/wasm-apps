{
  "name": "@wasm-apps/linker",
  "version": "1.4.0",
  "description": "Convierte archivos .wasm en ejecutables nativos usando C++ + Wasmtime",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "linker": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc --watch"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AndyTechnologies/wasm-apps.git",
    "directory": "packages/linker"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "linker",
    "native",
    "wasmtime"
  ],
  "author": "AndyTechnologies",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "cmake-js": "^8.0.0",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "lzma-native": "^8.0.6",
    "picocolors": "^1.1.1",
    "tar": "^7.5.20",
    "@wasm-apps/types": "workspace:*"
  },
  "devDependencies": {}
}
