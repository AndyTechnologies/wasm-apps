{
  "name": "@wasm-apps/compiler",
  "version": "1.4.0",
  "description": "Compila archivos AssemblyScript (.wasm.ts, .ts, .asm) a WebAssembly",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "compiler": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node ./dist/cli.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AndyTechnologies/wasm-apps.git",
    "directory": "packages/compiler"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "assemblyscript",
    "compiler"
  ],
  "author": "AndyTechnologies",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "assemblyscript": "^0.28.19",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "picocolors": "^1.1.1",
    "@wasm-apps/types": "workspace:*"
  }
}
